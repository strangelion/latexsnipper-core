{
  "model_type": "dbnet",
  "model_family": "PP-OCRv6 Small Text Detection",
  "license": "Apache-2.0",
  "task_type": "detection",
  "dynamic_shapes": true,
  "input": {
    "name": "x",
    "shape": [
      1,
      3,
      -1,
      -1
    ],
    "dtype": "float32",
    "range": [
      0.0,
      1.0
    ]
  },
  "output": {
    "name": "fetch_name_0",
    "shape": [
      1,
      1,
      -1,
      -1
    ],
    "description": "DBNet probability map"
  },
  "preprocessing": {
    "resize": {
      "keep_ratio": true,
      "pad_value": 0.0
    },
    "normalization": {
      "mean": [
        0.0,
        0.0,
        0.0
      ],
      "std": [
        1.0,
        1.0,
        1.0
      ]
    },
    "color_format": "BGR"
  },
  "postprocessing": {
    "type": "dbnet",
    "threshold": 0.3,
    "box_threshold": 0.5,
    "max_candidates": 1000,
    "unclip_ratio": 1.5
  }
}