{
  "model_type": "crnn_ctc",
  "model_family": "PP-OCRv6 Small Text Recognition",
  "license": "Apache-2.0",
  "task_type": "ocr",
  "dynamic_shapes": true,
  "input": {
    "name": "x",
    "shape": [
      1,
      3,
      48,
      3200
    ],
    "dtype": "float32",
    "range": [
      -1.0,
      1.0
    ]
  },
  "output": {
    "name": "fetch_name_0",
    "shape": [
      1,
      -1,
      18710
    ],
    "description": "CTC logits"
  },
  "preprocessing": {
    "resize": {
      "width": 3200,
      "height": 48,
      "keep_ratio": true,
      "pad_value": 0.0
    },
    "normalization": {
      "mean": [
        0.5,
        0.5,
        0.5
      ],
      "std": [
        0.5,
        0.5,
        0.5
      ]
    },
    "color_format": "BGR"
  },
  "decoding": {
    "type": "ctc_greedy",
    "blank_id": 0,
    "keys_file": "inference.yml"
  }
}